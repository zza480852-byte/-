-- [[ LOW GRAPHICS & ANTI-TREE SYSTEM ]]
local LOWG = {}

function LOWG.Activate()
    local Lighting = game:GetService("Lighting")
    local Terrain = workspace:FindFirstChildOfClass("Terrain")

    -- 1. ลบต้นไม้ (สแกนหาคำว่า Tree)
    for _, v in pairs(workspace:GetDescendants()) do
        if string.find(v.Name, "Tree") or string.find(v.Name, "tree") then
            v:Destroy()
        end
    end

    -- 2. ปรับ Material ให้ลื่นที่สุด (SmoothPlastic)
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") or v:IsA("MeshPart") or v:IsA("Part") then
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false -- ปิดเงาเฉพาะชิ้นส่วน
        end
    end

    -- 3. ตั้งค่าแสงและสภาพแวดล้อม
    settings().Rendering.QualityLevel = 1
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.Brightness = 2 -- เพิ่มความสว่างมาชดเชยเงาที่หายไป
    
    if Terrain then
        Terrain.WaterWaveSize = 0
        Terrain.WaterWaveSpeed = 0
        Terrain.WaterReflectance = 0
        Terrain.WaterTransparency = 0
    end

    -- 4. ระบบลบเอฟเฟกต์ (กันเหนี่ยวไว้ด้วย)
    workspace.DescendantAdded:Connect(function(v)
        if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Explosion") then
            task.wait()
            v:Destroy()
        end
    end)

    print("Extreme Low Graphics & Anti-Tree Activated!")
end

return LOWG
